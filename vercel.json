{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-laltex",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/embed-laltex",
      "schedule": "0 4 * * *"
    }
  ]
}
