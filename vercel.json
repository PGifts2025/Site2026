{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/ai/chat.js": {
      "includeFiles": "docs/ava-conversation-rules.md"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-laltex",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/embed-catalogue",
      "schedule": "0 4 * * *"
    }
  ]
}
