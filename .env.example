# Stripe API Keys
# Get your test keys from: https://dashboard.stripe.com/test/apikeys

# Publishable Key (starts with pk_test_)
# This is safe to use in client-side code
VITE_STRIPE_PUBLISHABLE_KEY=

# Secret Key (starts with sk_test_)
# KEEP THIS SECRET! Only use in server-side code
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET: set after registering the webhook endpoint in
# Stripe Dashboard → Webhooks → Add endpoint. Stripe generates the signing
# secret when the endpoint is created. Required by supabase/functions/stripe-webhook
# (signature verification via stripe.webhooks.constructEventAsync). Set via:
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_... --project-ref <ref>
# Format: starts with "whsec_". Test and live Stripe modes each have their
# own endpoint and their own signing secret — rotate alongside STRIPE_SECRET_KEY
# at go-live (CLAUDE.md §17.6).
STRIPE_WEBHOOK_SECRET=
# Stripe Server Port (default: 3001)
STRIPE_SERVER_PORT=3001

# API URL (for Stripe serverless functions)
# Development: http://localhost:3001
# Production: Your Vercel deployment URL (e.g., https://your-app.vercel.app)
VITE_API_URL=http://localhost:3001

# Supabase Configuration
# Get these values from https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional — the frontend falls back to ${VITE_SUPABASE_URL}/functions/v1 if unset.
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Laltex supplier API
# Used by scripts/sync-laltex-product.js (and future full-catalogue sync).
# Passed in a custom "API_KEY" HTTP header (NOT Authorization / Bearer).
# From Laltex admin (Anastasia). Never commit the real value.
LALTEX_API_KEY=your_key_here

# Supabase Personal Access Token (admin / server-side scripts only — not a client secret).
# Used by admin scripts (migrations, scripts/sync-laltex-product.js,
# scripts/embed-supplier-product.js) via the Management API SQL endpoint.
# Starts with "sbp_". Never commit.
SUPABASE_ACCESS_TOKEN=sbp_your_token_here

# OpenAI API key (restricted to embeddings usage only; never commit the real value).
# Used by scripts/embed-supplier-product.js and scripts/search-supplier-products.js
# to call the text-embedding-3-small model. Project-scoped keys start with "sk-proj-".
OPENAI_API_KEY=sk-proj-your_key_here

# Supabase service-role key (RLS-bypassing, server-side only, NEVER expose to client).
# Used by the nightly sync cron (api/cron/sync-laltex.js) + scripts/sync-laltex-catalogue.js
# to bulk-UPSERT into supplier_products via PostgREST. Copy from Supabase Dashboard ->
# Project Settings -> API -> service_role secret. Distinct from SUPABASE_ACCESS_TOKEN
# (which is a PAT for the Management API, not a client credential — see CLAUDE.md §27).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Shared secret for the Vercel Cron auth header.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set identically in site/.env AND in Vercel env vars for all environments.
# Vercel Cron is expected to send:  Authorization: Bearer ${CRON_SECRET}
# Missing or wrong secret -> 401. See docs/VERCEL_CRON_SETUP.md.
CRON_SECRET=your_64_char_hex_secret_here

# Public visibility flag for the AI chat widget. When 'true', anonymous
# visitors see the floating chat launcher AND the homepage Ava card
# can open the widget. When 'false' (default), the widget is only shown
# to signed-in users whose profiles.ai_chat_enabled is true (testing
# accounts). Must be set to 'true' in Vercel Production + Preview env
# at the same time the Ava homepage card is rolled out. CLAUDE.md §49.
VITE_AI_CHAT_PUBLIC_ENABLED=false

# Optional salt for the anonymous AI chat visitor-ID hash. Prevents
# brute-force recovery of FingerprintJS visitor IDs from ai_quotas
# rows if the service-role key ever leaks (defence-in-depth, not an
# active exploit surface). Hardening follow-up per CLAUDE.md §32.6 +
# §49. Generate fresh:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Empty value = no salt (rainbow-table-able). Set BEFORE public Ava rollout.
VISITOR_HASH_SALT=

# Testing Notes:
# For Stripe testing, use test card: 4242 4242 4242 4242
#    - Any future expiry date
#    - Any 3-digit CVC
#    - Any 5-digit ZIP code