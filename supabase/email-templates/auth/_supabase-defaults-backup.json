{
  "mailer_templates_confirmation_content": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: #1e3a5f; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }\n    .header h1 { color: white; margin: 0; font-size: 24px; }\n    .content { background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb; }\n    .button { display: inline-block; background: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold; margin: 20px 0; }\n    .footer { text-align: center; padding: 20px; color: #6b7280; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Promo Gifts</h1>\n    </div>\n    <div class=\"content\">\n      <h2>Welcome to Promo Gifts!</h2>\n      <p>Thanks for signing up. Please verify your email address to get started with your account.</p>\n      <p style=\"text-align: center;\">\n        <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Verify My Email</a>\n      </p>\n      <p>Or copy and paste this link into your browser:</p>\n      <p style=\"word-break: break-all; color: #2563eb;\">{{ .ConfirmationURL }}</p>\n      <p>If you didn't create an account with Promo Gifts, you can safely ignore this email.</p>\n    </div>\n    <div class=\"footer\">\n      <p>Promo Gifts - Your Promotional Partner</p>\n      <p>Unit 5, Cuddington Industrial Estate, Milton Keynes</p>\n    </div>\n  </div>\n</body>\n</html>",
  "mailer_templates_recovery_content": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: #1e3a5f; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }\n    .header h1 { color: white; margin: 0; font-size: 24px; }\n    .content { background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb; }\n    .button { display: inline-block; background: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold; margin: 20px 0; }\n    .footer { text-align: center; padding: 20px; color: #6b7280; font-size: 12px; }\n    .warning { background: #fef3c7; border: 1px solid #f59e0b; padding: 12px; border-radius: 6px; margin-top: 20px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Promo Gifts</h1>\n    </div>\n    <div class=\"content\">\n      <h2>Reset Your Password</h2>\n      <p>We received a request to reset the password for your Promo Gifts account.</p>\n      <p style=\"text-align: center;\">\n        <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Reset My Password</a>\n      </p>\n      <p>Or copy and paste this link into your browser:</p>\n      <p style=\"word-break: break-all; color: #2563eb;\">{{ .ConfirmationURL }}</p>\n      <div class=\"warning\">\n        <strong>⚠️ Didn't request this?</strong><br>\n        If you didn't request a password reset, please ignore this email. Your password will remain unchanged.\n      </div>\n    </div>\n    <div class=\"footer\">\n      <p>Promo Gifts - Your Promotional Partner</p>\n      <p>Unit 5, Cuddington Industrial Estate, Milton Keynes</p>\n    </div>\n  </div>\n</body>\n</html>",
  "mailer_templates_magic_link_content": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: #1e3a5f; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }\n    .header h1 { color: white; margin: 0; font-size: 24px; }\n    .content { background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb; }\n    .button { display: inline-block; background: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold; margin: 20px 0; }\n    .footer { text-align: center; padding: 20px; color: #6b7280; font-size: 12px; }\n    .expires { background: #e0e7ff; padding: 10px; border-radius: 6px; text-align: center; color: #3730a3; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Promo Gifts</h1>\n    </div>\n    <div class=\"content\">\n      <h2>Your Login Link</h2>\n      <p>Click the button below to securely sign in to your Promo Gifts account. No password needed!</p>\n      <p style=\"text-align: center;\">\n        <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Sign In to Promo Gifts</a>\n      </p>\n      <p>Or copy and paste this link into your browser:</p>\n      <p style=\"word-break: break-all; color: #2563eb;\">{{ .ConfirmationURL }}</p>\n      <div class=\"expires\">\n        🕐 This link expires in 1 hour for security reasons.\n      </div>\n      <p style=\"margin-top: 20px;\">If you didn't request this login link, you can safely ignore this email.</p>\n    </div>\n    <div class=\"footer\">\n      <p>Promo Gifts - Your Promotional Partner</p>\n      <p>Unit 5, Cuddington Industrial Estate, Milton Keynes</p>\n    </div>\n  </div>\n</body>\n</html>",
  "mailer_templates_email_change_content": "<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: #1e3a5f; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }\n    .header h1 { color: white; margin: 0; font-size: 24px; }\n    .content { background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb; }\n    .button { display: inline-block; background: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold; margin: 20px 0; }\n    .footer { text-align: center; padding: 20px; color: #6b7280; font-size: 12px; }\n    .info-box { background: #ecfdf5; border: 1px solid #10b981; padding: 12px; border-radius: 6px; margin: 15px 0; }\n    .warning { background: #fef3c7; border: 1px solid #f59e0b; padding: 12px; border-radius: 6px; margin-top: 20px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Promo Gifts</h1>\n    </div>\n    <div class=\"content\">\n      <h2>Confirm Your New Email</h2>\n      <p>You requested to change the email address associated with your Promo Gifts account.</p>\n      <div class=\"info-box\">\n        <strong>📧 New email:</strong> {{ .Email }}\n      </div>\n      <p>Please click the button below to confirm this change:</p>\n      <p style=\"text-align: center;\">\n        <a href=\"{{ .ConfirmationURL }}\" class=\"button\">Confirm Email Change</a>\n      </p>\n      <p>Or copy and paste this link into your browser:</p>\n      <p style=\"word-break: break-all; color: #2563eb;\">{{ .ConfirmationURL }}</p>\n      <div class=\"warning\">\n        <strong>⚠️ Didn't request this?</strong><br>\n        If you didn't request an email change, please contact us immediately and secure your account by resetting your password.\n      </div>\n    </div>\n    <div class=\"footer\">\n      <p>Promo Gifts - Your Promotional Partner</p>\n      <p>Unit 5, Cuddington Industrial Estate, Milton Keynes</p>\n    </div>\n  </div>\n</body>\n</html>",
  "mailer_subjects_confirmation": "Confirm Your Signup",
  "mailer_subjects_recovery": "Reset Your Password",
  "mailer_subjects_magic_link": "Your Magic Link",
